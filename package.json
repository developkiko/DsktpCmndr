{
  "name": "@developkiko/desktop-commander",
  "version": "1.2.7",
  "description": "MCP server for terminal operations and file editing (fork by Kiko)",
  "mcpName": "io.github.developkiko/desktop-commander",
  "license": "MIT",
  "author": "Kiko",
  "homepage": "https://github.com/developkiko/DsktpCmndr",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/developkiko/DsktpCmndr.git"
  },
  "bugs": "https://github.com/developkiko/DsktpCmndr/issues",
  "type": "module",
  "engines": {
    "node": ">=18.0.0"
  },
  "bin": {
    "desktop-commander": "dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "postinstall": "echo DsktpCmndr v1.2.7 installed",
    "build": "tsc && shx cp setup-claude-server.js uninstall-claude-server.js track-installation.js dist/ 2>nul && shx mkdir -p dist/data 2>nul && shx cp -r src/data/onboarding-prompts.json dist/data/ 2>nul && shx mkdir -p dist/remote-device/scripts 2>nul && shx cp src/remote-device/scripts/blocking-offline-update.js dist/remote-device/scripts/ 2>nul && node scripts/build-ui-runtime.cjs 2>nul",
    "watch": "tsc --watch",
    "start": "node dist/index.js",
    "start:debug": "node --inspect-brk=9229 dist/index.js",
    "setup": "npm install && npm run build",
    "clean": "shx rm -rf dist",
    "test": "npm run build && node test/run-all-tests.js"
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "terminal",
    "ai",
    "command-line",
    "process-management",
    "file-editing",
    "file-system"
  ],
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.9.0",
    "@opendocsg/pdf2md": "^0.2.2",
    "@supabase/supabase-js": "^2.89.0",
    "@tiptap/core": "^3.22.3",
    "@tiptap/extension-image": "^3.22.3",
    "@tiptap/extension-table": "^3.22.4",
    "@tiptap/extension-table-cell": "^3.22.4",
    "@tiptap/extension-table-header": "^3.22.4",
    "@tiptap/extension-table-row": "^3.22.4",
    "@tiptap/pm": "^3.22.3",
    "@tiptap/starter-kit": "^3.22.3",
    "@vscode/ripgrep": "^1.15.9",
    "cross-fetch": "^4.1.0",
    "exceljs": "^4.4.0",
    "fastest-levenshtein": "^1.0.16",
    "file-type": "^21.1.1",
    "glob": "^10.3.10",
    "highlight.js": "^11.11.1",
    "isbinaryfile": "^5.0.4",
    "markdown-it": "^14.1.0",
    "md-to-pdf": "^5.2.5",
    "open": "^10.2.0",
    "pdf-lib": "^1.17.1",
    "pizzip": "^3.2.0",
    "remark": "^15.0.1",
    "remark-gfm": "^4.0.1",
    "remark-parse": "^11.0.0",
    "sharp": "^0.34.5",
    "tiptap-markdown": "^0.9.0",
    "unified": "^11.0.5",
    "unpdf": "^1.4.0",
    "zod": "^3.24.1",
    "zod-to-json-schema": "^3.23.5"
  },
  "optionalDependencies": {
    "caffeinate": "^1.0.1"
  },
  "devDependencies": {
    "@anthropic-ai/mcpb": "^1.2.0",
    "@modelcontextprotocol/ext-apps": "^1.0.1",
    "@types/node": "^20.17.24",
    "commander": "^13.1.0",
    "esbuild": "^0.27.2",
    "js-tiktoken": "^1.0.21",
    "jsdom": "^24.1.3",
    "nexe": "^5.0.0-beta.4",
    "nodemon": "^3.0.0",
    "shx": "^0.3.4",
    "tsx": "^4.7.0",
    "typescript": "^5.7.0"
  }
}
